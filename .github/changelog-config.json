{
  "categories": [
    {
      "title": "🚀 Features",
      "labels": ["feat", "feature"]
    },
    {
      "title": "🐛 Fixes",
      "labels": ["fix", "bug"]
    },
    {
      "title": "⚡ Performance",
      "labels": ["perf"]
    },
    {
      "title": "🧱 Refactors",
      "labels": ["refactor"]
    },
    {
      "title": "📖 Documentation",
      "labels": ["docs", "doc"]
    },
    {
      "title": "⚙️ CI/CD",
      "labels": ["ci", "build"]
    },
    {
      "title": "🎨 Style & Themes",
      "labels": ["style", "theme"]
    },
    {
      "title": "🧪 Tests",
      "labels": ["test"]
    },
    {
      "title": "📦 Dependencies",
      "labels": ["chore(deps)", "dependencies", "chore"]
    }
  ],
  "ignore_labels": [
    "ignore"
  ],
  "template": "${{CHANGELOG}}\n\n<details>\n<summary><b>Full Commit History</b></summary>\n\n${{COMMITS}}\n</details>",
  "empty_template": "## All Changes\n${{COMMITS}}",
  "commit_template": "- ${{TITLE}} (${{HASH}})",
  "commit_template_without_pr": "- ${{TITLE}} (${{HASH}})",
  "pr_template": "- ${{TITLE}} (#${{NUMBER}})",
  "ignore_no_label": false,
  "label_extractor": [
    {
      "pattern": "^(feat|feature|fix|bug|refactor|docs|doc|test|chore|dependencies|style|theme|ci|build|perf)(\\(.*\\))?:.*",
      "target": "$1"
    }
  ]
}
